rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsResource() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingResource() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /lists/{listId} {
      allow read, delete: if ownsResource();
      allow create: if ownsIncomingResource();
      allow update: if ownsResource() && ownsIncomingResource();
    }

    match /items/{itemId} {
      allow read, delete: if ownsResource();
      allow create: if ownsIncomingResource();
      allow update: if ownsResource() && ownsIncomingResource();
    }
  }
}
